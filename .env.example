# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DATABASE_URL=sqlite:///instance/database.db

# Flask-Mail Configuration (for password reset)
# For Gmail:
# 1. Enable 2-Step Verification on your Google Account (https://myaccount.google.com/security)
# 2. Create an App Password (https://myaccount.google.com/apppasswords)
# 3. Use the App Password below, NOT your regular Gmail password!
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Google Cloud & Sheets Configuration
# 1. Create Google Cloud Project and enable Firestore and Sheets API
# 2. Create Service Account and download key as service-account-key.json
# 3. Create Google Sheet and share with service account email
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id
